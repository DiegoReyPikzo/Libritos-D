<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.biblio_teca.controlller.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Pane prefHeight="247.0" prefWidth="314.0">
         <children>
            <Label layoutX="76.0" layoutY="24.0" text="Libreria de libros">
               <font>
                  <Font name="Comic Sans MS" size="20.0" />
               </font>
            </Label>
            <Label layoutX="98.0" layoutY="52.0" text="Por favor inicie sesión">
               <font>
                  <Font name="Comic Sans MS" size="12.0" />
               </font></Label>
            <TextField fx:id="user" layoutX="74.0" layoutY="91.0" promptText="Usuario...">
               <font>
                  <Font name="Comic Sans MS" size="12.0" />
               </font></TextField>
            <TextField fx:id="contra" layoutX="74.0" layoutY="132.0" promptText="Contraseña...">
               <font>
                  <Font name="Comic Sans MS" size="12.0" />
               </font></TextField>
            <Button layoutX="113.0" layoutY="180.0" mnemonicParsing="false" onAction="#OnSesion" text="Iniciar sesión">
               <font>
                  <Font name="Comic Sans MS" size="12.0" />
               </font>
            </Button>
            <Label fx:id="errorLabel" layoutX="156.0" layoutY="218.0">
               <font>
                  <Font name="Comic Sans MS" size="12.0" />
               </font></Label>
         </children>
      </Pane>
   </children>
</VBox>
